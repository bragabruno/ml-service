# ─────────────────────────────────────────────────────────────────────────────
# ML Service — Non-secret configuration
# Secrets come from Doppler via: doppler run -- uvicorn ml_service.app.main:app
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM Provider ─────────────────────────────────────────────────────────────
# mock = deterministic, offline, reproducible (default)
# anthropic = real Claude via Anthropic API
LLM_PROVIDER=mock
# ANTHROPIC_API_KEY=          # via Doppler

# ── Postgres ─────────────────────────────────────────────────────────────────
# Password via Doppler: POSTGRES_PASSWORD
DATABASE_URL=postgresql://${POSTGRES_USER:-fraud_user}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB:-fraud_db}

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── MLflow ───────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5001

# ── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── Case management (HITL) ───────────────────────────────────────────────────
# mock = in-memory/log (default, offline) | http = POST reports/labels to the service
CASE_MGMT_PROVIDER=mock
# CASE_MGMT_URL=http://case-management:8080

# ── Service ──────────────────────────────────────────────────────────────────
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8000
LOG_LEVEL=INFO
ENVIRONMENT=local
