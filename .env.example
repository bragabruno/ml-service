# ── LLM Provider ──────────────────────────────────────────────
# mock = deterministic, offline, reproducible (default)
# anthropic = real Claude via Anthropic API
LLM_PROVIDER=mock
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── Database Targets ──────────────────────────────────────────
# DuckDB (local/demo, zero-infra)
DB_DUCKDB_PATH=./data/fraud.duckdb

# Postgres (prod-parity, via docker-compose)
DB_POSTGRES_HOST=localhost
DB_POSTGRES_PORT=5433
DB_POSTGRES_DB=fraud_db
DB_POSTGRES_USER=fraud_user
DB_POSTGRES_PASSWORD=fraud_pass

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6380

# ── MLflow ────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5001

# ── Kafka (optional) ─────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9093

# ── Service ───────────────────────────────────────────────────
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8000
LOG_LEVEL=INFO
ENVIRONMENT=local
